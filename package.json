{
  "name": "robot-mes-demarches",
  "private": true,
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "autoprefixer": "^10.4.21",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "cookie": "^1.1.1",
    "elliptic": "^6.6.1",
    "lodash": "^4.18.1",
    "micromatch": "^4.0.8",
    "node-forge": "^1.4.0",
    "nodemon": "^3.1.11",
    "path-to-regexp": "^8.4.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "sass": "^1.93.2",
    "websocket-extensions": "^0.1.4"
  },
  "scripts": {
    "build": "bun run build:css && bun run build:js",
    "lint": "sass-lint -v",
    "lint:fix": "sass-lint-auto-fix",
    "build:css": "bun run build:css:compile && bun run build:css:prefix",
    "build:css:compile": "sass ./app/assets/stylesheets/application.bootstrap.scss:./app/assets/builds/application.css --no-source-map --load-path=node_modules",
    "build:css:prefix": "postcss ./app/assets/builds/application.css --use=autoprefixer --output=./app/assets/builds/application.css",
    "build:js": "cp node_modules/bootstrap/dist/js/bootstrap.bundle.min.js app/assets/builds/bootstrap.bundle.min.js",
    "watch:css": "nodemon --watch ./app/assets/stylesheets/ --ext scss --exec \"bun run build:css\"",
    "postinstall": "bun run build:js"
  },
  "resolutions": {
    "braces": ">=3.0.3",
    "brace-expansion": "^5.0.6",
    "fast-uri": "^3.1.2",
    "follow-redirects": "^1.16.0"
  }
}
